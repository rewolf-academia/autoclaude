# Jira → Claude Code automation configuration
# Copy this file to ~/.jira-claude.env and fill in the values.
# Then run: ./install.sh

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@your-org.com

# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=REPLACE_ME

# Label to add to a Jira ticket to trigger automation
TRIGGER_LABEL=claude-automate

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal access token with repo + pull_requests:write scopes on the upstream repo
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=REPLACE_ME

# The canonical upstream repo that PRs are opened against
GITHUB_UPSTREAM_REPO=your-org/your-repo

# The GitHub user/org that owns the fork branches are pushed to
GITHUB_FORK_OWNER=your-org

# GitHub username to request as reviewer on every PR (leave empty to skip)
REVIEWER_GITHUB_USER=

# ── Paths ─────────────────────────────────────────────────────────────────────
# Override these if your layout differs from the defaults
# REPO_PATH=/home/claude/code/academia-app
# CLAUDE_BIN=/home/claude/.local/bin/claude
